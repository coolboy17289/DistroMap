# but don't ship pre-cached API responses.
.cache/api/all.json
.cache/api/manual_overrides.json
.cache/api/popularity.json
.cache/api/suggestions.json
.cache/api/debian_*.json
.cache/api/ubuntu_*.json
.cache/api/arch_*.json
.cache/api/fedora_*.json
.cache/api/gentoo_*.json
.cache/api/linux_*.json
.cache/api/manjaro_*.json
.cache/api/pop_*.json
.cache/api/nobara_*.json
.cache/api/slackware_*.json
.cache/api/endeavouros_*.json
