# ── Python virtualenv leftovers from earlier backend prototyping ──
# (the suggestion API is now a TS serverless function at frontend/api/index.ts;
#  these .venv-* dirs are just unused weight at the repo root)
.venv-*/

# ── Python bytecode cache ─────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Working data cache (rebuilt by .cache/fetch_distros.py +
#    .cache/build_distro_files.py + .cache/fetch_popularity.py) ──
.cache/

# ── Node — only matters inside frontend/, but ignore at the root
#        in case anything else ends up with node_modules ──
node_modules/

# ── Vite build output, in case frontend/dist/ escapes the project root
dist/

# ── TypeScript incremental build cache files. frontend/tsc emits
#    tsconfig.tsbuildinfo + tsconfig.node.tsbuildinfo next to the
#    tsconfigs; without this line they'd appear in `git status` on
#    the first commit and confuse anyone re-running typecheck. ──
*.tsbuildinfo

# ── Vite dep-pre-bundle cache (regenerated by vite on first `npm run dev`) ──
.vite/

# ── OS / editor noise ─────────────────────────────────────────────
.DS_Store
*.log
Thumbs.db
