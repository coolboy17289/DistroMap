# Python venv leftovers from prior backend prototyping.
# The suggestion API is now a TS serverless function at
# frontend/api/index.ts; these .venv-* dirs are just unused weight.
.venv-*/

# Python bytecode cache.
__pycache__/
*.pyc
*.pyo

# Working data cache (rebuilt by .cache/fetch_distros.py +
# .cache/build_distro_files.py + .cache/fetch_popularity.py).
.cache/

# Node modules at any depth.
node_modules/

# Vite build output (`npm run build` -> frontend/dist/).
dist/

# TypeScript incremental build cache files. tsc emits
# tsconfig.tsbuildinfo + tsconfig.node.tsbuildinfo next to the
# tsconfigs; without this line they'd appear in git status and
# confuse anyone re-running typecheck.
*.tsbuildinfo

# Vite dep-pre-bundle cache (regenerated by vite on first
# `npm run dev`).
.vite/

# Vercel CLI artefacts (created by `vercel link`, `vercel env pull`,
# etc.; harmless but noisy in `git status` once they appear).
.vercel/

# Environment secrets at any depth. Mirror frontend/.gitignore so a
# stray root-level .env.local from a future monorepo tool (turbo,
# nx, etc.) can't leak. Same template exception as
# frontend/.gitignore so the example file stays tracked.
.env
.env.*
!.env.example

# OS / editor noise.
.DS_Store
*.log
Thumbs.db
